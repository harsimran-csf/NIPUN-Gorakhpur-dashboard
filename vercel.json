{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET",
        "Cache-Control": "s-maxage=300, stale-while-revalidate=600"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}